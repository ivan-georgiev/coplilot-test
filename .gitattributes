# Normalize all text files and store them in the repository with LF line endings.
* text=auto eol=lf

# Explicitly enforce LF on common cross-platform text files.
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.properties text eol=lf

# Avoid normalizing binary files.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.jar binary
*.exe binary
*.dll binary
